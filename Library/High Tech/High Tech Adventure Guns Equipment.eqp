			],
			"base_value": "20",
			"base_weight": "1.3 lb",
			"weapons": [
				{
					"id": "WpDOAMyPdJjxS8xXv",
					"sv": 1,
					"damage": {
						"type": "cr ex",
						"base": "5d",
						"fragmentation": "2d",
						"fragmentation_type": "cut"
					},
					"usage_notes": "Impact fuse. Range \u003cscript\u003elet weightRatio = self.attachedTo.weight/entity.encumbrance.basicLift\n\nfunction distanceModifier(wr) {\n  if (wr \u003c= 0.05) {return 3.5} else\n  if (wr \u003c= 0.10) {return 2.5} else\n  if (wr \u003c= 0.15) {return 2.0} else\n  if (wr \u003c= 0.20) {return 1.5} else\n  if (wr \u003c= 0.25) {return 1.2} else\n  if (wr \u003c= 0.30) {return 1.1} else\n  if (wr \u003c= 0.40) {return 1.0} else\n  if (wr \u003c= 0.50) {return 0.8} else\n  if (wr \u003c= 0.75) {return 0.7} else\n  if (wr \u003c= 1.0) {return 0.60} else\n  if (wr \u003c= 1.5) {return 0.40} else\n  if (wr \u003c= 2.0) {return 0.30} else\n  if (wr \u003c= 2.5) {return 0.25} else\n  if (wr \u003c= 3) {return 0.20} else\n  if (wr \u003c= 4) {return 0.15} else\n  if (wr \u003c= 5) {return 0.12} else\n  if (wr \u003c= 6) {return 0.10} else\n  if (wr \u003c= 7) {return 0.09} else\n  if (wr \u003c= 8) {return 0.08} else\n  if (wr \u003c= 9) {return 0.07} else\n  if (wr \u003c= 10) {return 0.06} else\n  {return 0.05}\n}\n\nfunction throwBonus() {\n  return Math.max(\n    Math.min(entity.skillLevel(\"Throwing\",\"\",true), 2),\n    Math.min(entity.skillLevel(\"Throwing Art\",\"\",true) - $dx + 1, 2),\n    0\n  ) \n}\n\nformatNum((distanceModifier(weightRatio)*(entity.strikingStrength+throwBonus())).toFixed(2),true)\u003c/script\u003e yd.",
					"shots": "T",
					"bulk": "-3",
					"defaults": [
						{
							"type": "skill",
							"name": "Throwing"
						},
						{
							"type": "skill",
							"name": "Throwing Art"
						},
						{
							"type": "dx",
							"modifier": -3
						},
						{
							"type": "skill",
							"name": "Dropping",
							"modifier": -4
						}
					],
					"calc": {
						"damage": "5d cr ex [2d cut]"
					}
				}
			],
			"quantity": 1,
			"equipped": true,
			"calc": {
				"value": 20,
				"extended_value": 20,
				"weight": "1.3 lb",
				"extended_weight": "1.3 lb"
			}
		},
