		{
			"id": "ei_G7PJXCAPd4fKq2",
			"description": "Ketchum Grenade",
			"reference": "HTAG46",
			"local_notes": "Malf 16. Impact fuse.",
			"tech_level": "5",
			"legality_class": "1",
			"tags": [
